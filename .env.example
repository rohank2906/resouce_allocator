# =========================================================================
# Resource Allocator - Production Environment Template
# =========================================================================
# Copy to .env (local) or paste each variable into Vercel > Project >
# Settings > Environment Variables for Production + Preview + Development.
# =========================================================================

# ---- Database (Postgres) -----------------------------------------------
# Production: Neon, Vercel Postgres, or Supabase. Connection pooling URL.
# Example (Neon pooled): postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL=""
# Direct (non-pooled) connection used by `prisma migrate`. Same DB, different host.
# Example (Neon direct): postgresql://user:pass@ep-xxx.region.aws.neon.tech/db?sslmode=require
DIRECT_URL=""

# ---- NextAuth ----------------------------------------------------------
# Local: http://localhost:3000
# Production: exact deployed URL (e.g. https://resource-allocator.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
# Generate fresh: openssl rand -base64 48
NEXTAUTH_SECRET=""

# ---- Login behaviour ---------------------------------------------------
ALLOW_PASSWORD_LOGIN="true"

# ---- Email (optional - notifications) ----------------------------------
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="Resource Allocator <noreply@ethara.ai>"

# ---- Google Sheets (Employees roster) ----------------------------------
GOOGLE_SHEET_ID="1Xingh0scld54zEbwNYRoI0Cv6NPF2tmy53Cns4J9dio"
GOOGLE_SHEET_RANGE="Sheet1!A:D"

# ---- Google Sheets (Resource Segregation - attendance + project moves) -
GOOGLE_RS_SHEET_ID="1W76v3knMY7iJrTZT1TWk3nLMKWTTJ4MSdA6l-tcIoUM"
GOOGLE_RS_SHEET_RANGE="Resource Segregation!A:N"

# ---- Google Service Account credentials --------------------------------
# Both required for sheet reads on Vercel. Share both sheets with this email.
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
# Full PEM string. Wrap in quotes. Newlines as literal \n (Vercel handles this when pasting).
GOOGLE_PRIVATE_KEY=""

# ---- Sync cron security (optional) -------------------------------------
# Shared secret for Vercel Cron POST /api/sync etc.
SYNC_CRON_SECRET=""

# =========================================================================
# Ethara Assistant (LLM)
# =========================================================================
# The assistant uses any OpenAI-compatible chat completions endpoint.
#
# RECOMMENDED PRODUCTION: Groq (free tier, very fast, OpenAI-compatible)
#   LLM_API_BASE_URL="https://api.groq.com/openai/v1"
#   LLM_API_KEY="gsk_xxx"  (from https://console.groq.com/keys)
#   LLM_MODEL="llama-3.3-70b-versatile"  or  "qwen/qwen3-32b"
#
# LOCAL DEV (Ollama on your machine):
#   LLM_API_BASE_URL="http://127.0.0.1:11434/v1"
#   LLM_API_KEY="ollama"   (Ollama ignores it; any non-empty value works)
#   LLM_MODEL="qwen2.5-coder:14b"
#
# OTHER OPENAI-COMPATIBLE PROVIDERS supported out of the box:
#   - OpenAI:        https://api.openai.com/v1
#   - Together.ai:   https://api.together.xyz/v1
#   - OpenRouter:    https://openrouter.ai/api/v1
#   - Anthropic:     not OpenAI-compatible; not supported by this client
# =========================================================================
LLM_API_BASE_URL=""
LLM_API_KEY=""
LLM_MODEL=""
LLM_TIMEOUT_MS="120000"

# Legacy Ollama variables (still read as fallback if the LLM_* are unset).
# Leave blank in production if you set LLM_* above.
OLLAMA_HOST=""
OLLAMA_MODEL=""
OLLAMA_TIMEOUT_MS=""
